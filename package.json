  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "ajv": "^8.17.1",
    "msw": "^2.12.7",
    "prettier": "2.2.1",
    "react-scripts": "^5.0.1"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "blueimp-md5": "^2.7.0",
    "classnames": "^2.2.5",
    "firebase": "^10.7.1",
    "firebase-tools": "^3.2.1",
    "firebaseui": "^6.1.0",
    "immutable": "^3.8.1",
    "moviedb": "^0.2.7",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.21.0",
    "redux": "^4.2.1",
    "redux-localstorage": "^0.4.1",
    "redux-saga": "^0.14.3",
    "reselect": "^2.5.4",
    "shortid": "^2.2.6"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:mock": "REACT_APP_USE_MOCK_DATA=true react-scripts start",
    "start:mock:progress": "REACT_APP_USE_MOCK_DATA=true REACT_APP_MOCK_SCENARIO=inProgress react-scripts start",
    "start:mock:early": "REACT_APP_USE_MOCK_DATA=true REACT_APP_MOCK_SCENARIO=earlyProgress react-scripts start",
    "start:mock:completed": "REACT_APP_USE_MOCK_DATA=true REACT_APP_MOCK_SCENARIO=completed react-scripts start",
    "build": "react-scripts build",
    "build:prod": "REACT_APP_ENVIRONMENT=production react-scripts build",
    "build:staging": "REACT_APP_ENVIRONMENT=staging react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "test:coverage": "react-scripts test --coverage --watchAll=false --env=jsdom",
    "test:integration": "react-scripts test --testPathPattern=__integration__ --env=jsdom",
    "test:unit": "react-scripts test --testPathIgnorePatterns=__integration__ --env=jsdom",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
